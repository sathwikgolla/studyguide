PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/prepflow
NODE_ENV=development

# Required for JWT auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
# Optional, default 7d
JWT_EXPIRES_IN=7d

# Set to 1 in production if the process should exit when MongoDB is unreachable (default: keep API up for /health)
# EXIT_ON_DB_FAILURE=1
